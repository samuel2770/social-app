# ─── Server ────────────────────────────────────────────────
PORT=5000

# ─── MongoDB ───────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/social_app

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=1h

# ─── Environment ───────────────────────────────────────────
NODE_ENV=development
